{
  "manifest_version": 3,
  "name": "CodeSign 切图助手",
  "version": "1.0.0",
  "description": "下载切图时自动调用本地 qt 工具处理",
  "permissions": [
    "storage",
    "downloads",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "*://codesign.qq.com/*",
    "*://*.codesign.qq.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://codesign.qq.com/*",
        "*://*.codesign.qq.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title" : "CodeSign 切图助手",
    "default_icon": {
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "48": "icons/icon48.png"
  }
}